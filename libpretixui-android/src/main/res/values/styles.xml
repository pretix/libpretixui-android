<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme.Dialog.ShortAnimation">
        <item name="android:windowEnterAnimation">@anim/enter_short</item>
        <item name="android:windowExitAnimation">@anim/exit_short</item>
    </style>

    <style name="AppTheme.Dialog" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">@color/pretix_brand_light</item>
        <item name="colorPrimaryDark">@color/pretix_brand_dark</item>
        <item name="colorAccent">@color/pretix_brand_green</item>
        <item name="android:windowActionBarOverlay">true</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>